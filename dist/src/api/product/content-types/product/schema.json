{
    "kind": "collectionType",
    "collectionName": "products",
    "info": {
        "singularName": "product",
        "pluralName": "products",
        "displayName": "Product"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string"
        },
        "cover_media": {
            "type": "media",
            "multiple": true,
            "allowedTypes": [
                "images",
                "files",
                "videos",
                "audios"
            ]
        },
        "variants": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::variant.variant",
            "mappedBy": "product"
        },
        "slug": {
            "type": "uid",
            "targetField": "name"
        },
        "description": {
            "type": "richtext"
        },
        "pricing": {
            "type": "component",
            "component": "attributes.price",
            "repeatable": false
        },
        "categories": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::category.category",
            "mappedBy": "products"
        },
        "sub_categories": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::sub-category.sub-category",
            "mappedBy": "products"
        },
        "seo": {
            "type": "component",
            "component": "attributes.seo",
            "repeatable": false
        }
    }
}
